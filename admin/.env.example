# Copy to admin/.env (gitignored) and fill in.
# Used by admin/scripts/release.sh to upload builds to Firebase App Distribution.

# Firebase App IDs — find them in Firebase console:
#   Project settings → General → Your apps → App ID
# Format: 1:<PROJECT_NUMBER>:<PLATFORM>:<HASH>
FIREBASE_ANDROID_APP_ID=1:000000000000:android:0000000000000000000000
FIREBASE_IOS_APP_ID=1:000000000000:ios:0000000000000000000000

# Choose ONE of the two — testers OR groups. Groups are easier to manage long-term.
FIREBASE_TESTER_GROUPS=admins
# FIREBASE_TESTERS=consciousmayank@gmail.com
