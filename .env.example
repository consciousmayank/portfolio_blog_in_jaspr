# Real .env lives at /srv/portfolio_blog/.env on the VPS — never commit it.
# Generate strong secrets locally (e.g. `openssl rand -hex 32`).

# Postgres
DB_PASSWORD=replace-with-32-random-chars
DATABASE_URL=postgres://portfolio:replace-with-32-random-chars@postgres:5432/portfolio

# API auth
JWT_SECRET=replace-with-64-random-chars

# Gmail SMTP via App Password (https://myaccount.google.com/apppasswords)
GMAIL_USER=consciousmayank@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
ADMIN_EMAIL=consciousmayank@gmail.com

# First-boot admin seed. Cleared from memory after the row is created; rotate
# the password via POST /api/admin/password after first login.
SEED_ADMIN_EMAIL=consciousmayank@gmail.com
SEED_ADMIN_PASSWORD=change-me-after-first-login

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=https://mayankjoshi.in,https://admin.mayankjoshi.in
